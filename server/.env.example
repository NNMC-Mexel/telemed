HOST=0.0.0.0
PORT=1340
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
# Production must use PostgreSQL. SQLite is local development only.
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=medconnect
DATABASE_USERNAME=medconnect
DATABASE_PASSWORD=change-me
DATABASE_SSL=false

FRONTEND_URL=http://localhost:1342

# Set to true in production to block patients from bypassing payment.
PAYMENTS_LIVE=false
RATE_LIMIT_ENABLED=true

# Required for automatic refunds when PAYMENTS_LIVE=true.
SIGNALING_SERVER_URL=http://localhost:1341

# Shared secret for Strapi <-> signaling-server internal calls.
# Set the same value in signaling-server/.env.
SIGNALING_INTERNAL_SECRET=change-me

# Optional MinIO/S3 private upload storage.
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=change-me
# MINIO_SECRET_KEY=change-me
# MINIO_BUCKET=medconnect
# STRAPI_URL=http://localhost:1340
