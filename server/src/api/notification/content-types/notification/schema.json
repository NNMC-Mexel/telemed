{
  "kind": "collectionType",
  "collectionName": "notifications",
  "info": {
    "singularName": "notification",
    "pluralName": "notifications",
    "displayName": "Notification"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "message": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "default": "system",
      "enum": [
        "appointment",
        "reminder",
        "message",
        "document",
        "video",
        "system"
      ]
    },
    "isRead": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "string"
    },
    "metadata": {
      "type": "json"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
