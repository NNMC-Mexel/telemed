# API URL (Strapi backend)
VITE_API_URL=http://localhost:1340

VITE_SIGNALING_SERVER=http://localhost:1341

# Production builds default to live payments unless explicitly set to false.
VITE_PAYMENTS_LIVE=false
VITE_EPAY_TEST=true

# TURN credentials are public to browsers. For production prefer ephemeral
# credentials from a backend endpoint instead of static long-lived secrets.
VITE_TURN_URL=turn:localhost:3478
VITE_TURN_URL_TCP=
VITE_TURN_INTERNAL=
VITE_TURN_USERNAME=medconnect
VITE_TURN_CREDENTIAL=change-me
